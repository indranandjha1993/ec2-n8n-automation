global:
  scrape_interval: {{ monitoring.prometheus.scrape_interval }}
  evaluation_interval: {{ monitoring.prometheus.scrape_interval }}

rule_files:
  # - "first_rules.yml"
  # - "second_rules.yml"

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ monitoring.prometheus.port }}']

  - job_name: 'node'
    static_configs:
      - targets: ['localhost:{{ monitoring.node_exporter.port }}']

  - job_name: 'n8n'
    static_configs:
      - targets: ['localhost:{{ n8n.port }}']
    metrics_path: '/metrics'
    scrape_interval: 30s

  - job_name: 'nginx'
    static_configs:
      - targets: ['localhost:9113']  # nginx-prometheus-exporter if installed
    scrape_interval: 30s
