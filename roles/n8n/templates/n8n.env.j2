# n8n Environment Configuration
NODE_ENV=production
N8N_CONFIG_FILE={{ n8n.home_dir }}/.n8n/config.json
N8N_USER_FOLDER={{ n8n.home_dir }}/.n8n
N8N_LOG_LEVEL={{ n8n.log_level }}
N8N_LOG_OUTPUT=file
N8N_LOG_FILE_LOCATION=/var/log/n8n/n8n.log
N8N_METRICS=true
N8N_DIAGNOSTICS_ENABLED=true
TZ={{ n8n.timezone }}
HOME={{ n8n.home_dir }}
