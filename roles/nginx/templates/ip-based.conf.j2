# IP-based configuration - services accessible via different ports

# Default server block for port 80
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    
    location / {
        return 301 http://$host:{{ service_ports.n8n }};
    }
    
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }
}

# n8n service on port {{ service_ports.n8n }}
server {
    listen {{ service_ports.n8n }};
    listen [::]:{{ service_ports.n8n }};
    server_name _;
    
    client_max_body_size {{ nginx.client_max_body_size }};
    
    location / {
        proxy_pass http://127.0.0.1:{{ n8n.port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
}

