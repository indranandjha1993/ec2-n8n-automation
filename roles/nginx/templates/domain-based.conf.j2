# Domain-based configuration with SSL - services accessible via subdomains

# HTTP to HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name {{ subdomains.n8n }}.{{ domain_name }} {{ subdomains.grafana }}.{{ domain_name }} {{ subdomains.prometheus }}.{{ domain_name }} {{ subdomains.pgadmin }}.{{ domain_name }};
    
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    
    location / {
        return 301 https://$server_name$request_uri;
    }
}

# n8n service
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ subdomains.n8n }}.{{ domain_name }};
    
    ssl_certificate /etc/letsencrypt/live/{{ subdomains.n8n }}.{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ subdomains.n8n }}.{{ domain_name }}/privkey.pem;
    
    client_max_body_size {{ nginx.client_max_body_size }};
    
    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    
    location / {
        proxy_pass http://127.0.0.1:{{ n8n.port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
}

